# ============================================
# AI 企业数字化工作台 - 后端环境变量配置
# ============================================
# 复制本文件为 .env 并填入实际值
# cp .env.example .env

# ─── 服务端口 ───────────────────────────────
PORT=3001

# ─── JWT 密钥（必须修改为随机字符串！） ───────
JWT_SECRET=myaiworkspace_secret_key_2026-6
JWT_EXPIRES_IN=7d

# ─── MySQL 数据库 ───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_workspace
DB_USER=root
DB_PASSWORD=root

# ─── DeepSeek AI ────────────────────────────

DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
